# Copy this file to .env and fill in your values
# Anna will provide the Supabase values after setting up the project

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI — use Anna's proxy endpoint, not the key directly
EXPO_PUBLIC_OPENAI_PROXY_URL=https://your-proxy.supabase.co/functions/v1/openai-proxy
